-- 작품(공용)
CREATE TABLE WORK (
    WORKID INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    WORKTYPE ENUM('BOOK','WEBTOON','MOVIE','SERIES'),
    WORKTITLE VARCHAR(100),
    WORKDESC VARCHAR(5000),
    WORKTHUMBNAIL VARCHAR(100),
    WORKPUBLISHDATE DATE,
    WRITERID INT NULL,
    HOTSCORE INT,
    WORKRANK INT,
    FOREIGN KEY (WRITERID) REFERENCES WRITER(WRITERID)
);

-- 인물(Person)
CREATE TABLE PERSON (
    PERSONID INT AUTO_INCREMENT PRIMARY KEY,
    NAME VARCHAR(100),
    PROFILEURL VARCHAR(300)
)

-- 인물-작품 연결(PERSON_WORK)
CREATE TABLE PERSON_WORK (
    ROLETYPE VARCHAR(50),
    PERSONID INT,
    WORKID INT NOT NULL,
    CHARACTERNAME VARCHAR(50),
    PRIMARY KEY (ROLETYPE, PERSONID, WORKID),
    FOREIGN KEY (PERSONID) REFERENCES PERSON(PERSONID),
    FOREIGN KEY (WORKID) REFERENCES WORK(WORKID)
		ON DELETE CASCADE
);

-- 장르(Genre)
CREATE TABLE GENRE (
    GENREID INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    GENRENAME VARCHAR(50) NOT NULL UNIQUE
);

-- 시리즈디테일(SeriesDetail)
CREATE TABLE SERIESDETAIL (
    WORKID INT NOT NULL PRIMARY KEY,
    COUNTRY VARCHAR(50),
    AGERATING VARCHAR(20),
    FOREIGN KEY (WORKID) REFERENCES WORK(WORKID)
    ON DELETE CASCADE
);

-- 작품-장르연결(WORK_GENRE)
CREATE TABLE WORK_GENRE (
    WORKID INT NOT NULL,
    GENREID INT NOT NULL,
    PRIMARY KEY (WORKID, GENREID),
    FOREIGN KEY (WORKID) REFERENCES WORK(WORKID)
    ON DELETE CASCADE,
    FOREIGN KEY (GENREID) REFERENCES GENRE(GENREID)
);

-- 영화디테일(MovieDetail)
CREATE TABLE MOVIEDETAIL (
    WORKID INT NOT NULL PRIMARY KEY,
    COUNTRY VARCHAR(50),
    RUNNINGTIME INT,
    BOOKINGRATE DECIMAL(5,2),
    AGERATING VARCHAR(20),
    TOTALAUDIENCE INT,
    FOREIGN KEY (WORKID) REFERENCES WORK(WORKID)
    ON DELETE CASCADE
);

-- 소식(Notification)
CREATE TABLE NOTIFICATION (
    NOTIFICATIONID INT AUTO_INCREMENT PRIMARY KEY,
    RECEIVERID VARCHAR(100),
    SENDERID VARCHAR(100),
    NOTIFICATIONTYPE ENUM('FOLLOW','RATING','COMMENT','EVENT'),
    TARGETID INT,
    ISREAD BOOLEAN,
    CREATEDATE DATETIME,
    EVENTID INT,
    FOREIGN KEY (RECEIVERID) REFERENCES MEMBER(MEMBERID) ON DELETE CASCADE,
    FOREIGN KEY (SENDERID) REFERENCES MEMBER(MEMBERID),
    FOREIGN KEY (EVENTID) REFERENCES EVENT(EVENTID)
);

-- 이벤트(Event)
CREATE TABLE EVENT (
    EVENTID INT AUTO_INCREMENT PRIMARY KEY,
    EVENTTITLE VARCHAR(200),
    EVENTSUMMARY VARCHAR(500),
    EVENTIMAGE VARCHAR(300),
    EVENTLINK VARCHAR(500),
    EVENTSTARTDATE DATETIME,
    EVENTENDDATE DATETIME,
    EVENTCREATEDATE DATETIME
);

-- 매거진(Magazine)
CREATE TABLE MAGAZINE (
    MAGAZINEID INT AUTO_INCREMENT PRIMARY KEY,
    MAGAZINETITLE VARCHAR(200),
    MAGAZINESUMMARY VARCHAR(500),
    MAGAZINECONTENT TEXT,
    MAGAZINETHUMBNAIL VARCHAR(300),
    MAGAZINEVIEWCOUNT INT,
    MAGAZINECREATEDATE DATE,
    MAGAZINECATEGORYID INT,
    MEMBERID VARCHAR(100) NOT NULL,
    FOREIGN KEY (MAGAZINECATEGORYID) REFERENCES MAGAZINECATEGORY(MAGAZINECATEGORYID),
    FOREIGN KEY (MEMBERID) REFERENCES MEMBER(MEMBERID)
		ON DELETE CASCADE
);

-- 매거진상세페이지(MagazineDetail)
CREATE TABLE MAGAZINEDETAIL (
    MAGAZINEDETAILID INT AUTO_INCREMENT PRIMARY KEY,
    MAGAZINEID INT,
    MAGAZINEDETAILTYPE VARCHAR(10),
    MAGAZINEDETAILTEXT TEXT,
    MAGAZINEDETAILIMAGEPATH VARCHAR(300),
    MAGAZINEDETAILORDER INT,
    FOREIGN KEY (MAGAZINEID) REFERENCES MAGAZINE(MAGAZINEID)
);

-- 매거진카테고리(MagazineCategory)
CREATE TABLE MAGAZINECATEGORY (
    MAGAZINECATEGORYID INT AUTO_INCREMENT PRIMARY KEY,
    MAGAZINECATEGORYNAME VARCHAR(50)
);
